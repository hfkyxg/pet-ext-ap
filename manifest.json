{
  "manifest_version": 3,
  "name": "Claw'd: Companheiro de Navegação",
  "version": "1.1.0",
  "description": "Um mascote interativo e orquestrador de IA direto no navegador.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["src/content/style.css"],
      "js": ["src/content/content.js"]
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Menu do Claw'd"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/assets/*.png", "src/assets/*.gif"],
      "matches": ["<all_urls>"]
    }
  ]
}